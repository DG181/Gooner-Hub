-- Gooner Hub | Loader
local _game = game
local _loadstring = loadstring
local _pcall = pcall
local _tostring = tostring
local _warn = warn

--NOTIFY
local function notify(title, msg, dur)
    _pcall(function()
        _game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = title,
            Text = msg,
            Duration = dur or 4
        })
    end)
end

--GAME DETECTION
local function getUrl()
    local pid = _tostring(_game.PlaceId)
    local gid = _tostring(_game.GameId)

    -- 99 Nights
    if pid == "126509999114328" or pid == "79546208627805" or gid == "7326934954" then
        return "https://raw.githubusercontent.com/DG181/Gooner-Hub/refs/heads/main/99nights"

    -- Zoo / Oof
    elseif pid == "139233844569220" then
        return "https://raw.githubusercontent.com/DG181/Gooner-Hub/refs/heads/main/Zoo%20or%20Oof"

    -- Rivals
    elseif pid == "17625359962" or pid == "6035872082" then
        return "https://raw.githubusercontent.com/DG181/Gooner-Hub/refs/heads/main/Rivals%20Script.lua"
    end

    return nil
end

--MAIN RUN
local function run()
    local url = getUrl()

    if not url then
        local pid = _tostring(_game.PlaceId)
        _warn("[GoonerHub] unsupported place -> " .. pid)
        notify("Gooner Hub", "Not supported (" .. pid .. ")", 5)
        return
    end

    
    local ok1, content = _pcall(function()
        return _game:HttpGet(url, true)
    end)

    if not ok1 then
        _warn("[GoonerHub] fetch failed -> " .. _tostring(content))
        notify("Gooner Hub", "Failed to fetch script", 4)
        return
    end

    if not content or #content < 10 then
        _warn("[GoonerHub] empty or invalid response")
        notify("Gooner Hub", "Invalid script response", 4)
        return
    end

    
    local fn, compErr = _loadstring(content)
    if not fn then
        _warn("[GoonerHub] compile error -> " .. _tostring(compErr))
        notify("Gooner Hub", "Compile error", 4)
        return
    end

    local ok2, runErr = _pcall(fn)
    if not ok2 then
        _warn("[GoonerHub] runtime error -> " .. _tostring(runErr))
        notify("Gooner Hub", "Execution failed (check console)", 4)
    end
end


run()
